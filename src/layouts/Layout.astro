---
interface Props {
  title: string;
  description: string;
}

const siteUrl = "https://baitululum-alusmani.com";
const { title, description } = Astro.props;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Pondok Pesantren Baitul 'Ulum Wal Huffadz Al Usmani",
  "alternateName": "Pesantren Al Usmani",
  "url": siteUrl,
  "logo": `${siteUrl}/images/logo.jpeg`,
  "image": `${siteUrl}/images/og-card.png`,
  "description": description,
  "telephone": "+6281779055909",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jl. Wiru Indah I, Parung Serab",
    "addressLocality": "Ciledug",
    "addressRegion": "Kota Tangerang, Banten",
    "addressCountry": "ID"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": -6.2383,
    "longitude": 106.7143
  },
  "sameAs": [
    "https://www.instagram.com/ponpes_al_usmani/"
  ]
};
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0a" />
    <!-- Canonical -->
    <link rel="canonical" href={siteUrl} />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}/images/og-card.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Pondok Pesantren Al Usmani — Tumbuh dalam ilmu. Berakar dalam adab." />
    <meta property="og:locale" content="id_ID" />
    <meta property="og:site_name" content="Pondok Pesantren Al Usmani" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}/images/og-card.png`} />
    <!-- Icons & Manifest -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/images/favicon-180.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500;1,600&display=swap"
      rel="stylesheet"
    />
    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
